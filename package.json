{
  "name": "turn-over",
  "version": "0.1.0",
  "private": true,
  "main": "electron-dist/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "electron:compile": "tsc --project electron/tsconfig.json",
    "electron:dev": "npm run electron:compile && concurrently -k -s first -n \"NEXT,ELECTRON\" --prefix-colors \"cyan,yellow\" \"next dev\" \"wait-on http://localhost:3000 && cross-env NODE_ENV=development electron .\"",
    "electron:dev:remote": "npm run electron:compile && cross-env NODE_ENV=development ELECTRON_BASE_URL=https://turn-over-eight.vercel.app electron .",
    "electron:build": "next build && npm run electron:compile && electron-builder",
    "electron:pack": "next build && npm run electron:compile && electron-builder --dir"
  },
  "build": {
    "appId": "com.turnover.flashcard",
    "productName": "Turn-Over",
    "mac": {
      "category": "public.app-category.education",
      "icon": "electron/dock-icon.png",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "entitlementsLoginHelper": "electron/entitlements.mac.plist",
      "entitlements": "electron/entitlements.mac.plist",
      "extendInfo": {
        "NSAppleEventsUsageDescription": "Turn-Over uses Accessibility to read selected text when adding flashcards via the global shortcut.",
        "NSAccessibilityUsageDescription": "Turn-Over uses Accessibility to read selected text when adding flashcards via the global shortcut."
      }
    },
    "win": {
      "target": "nsis"
    },
    "files": [
      "electron-dist/**/*"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "app",
        "filter": [
          "**/*",
          "!**/.git"
        ]
      },
      {
        "from": ".next/standalone/node_modules",
        "to": "app/node_modules",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": ".next/standalone/.next",
        "to": "app/.next",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": ".next/static",
        "to": "app/.next/static",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "public",
        "to": "app/public",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "electron/tray-icon.png",
        "to": "tray-icon.png"
      },
      {
        "from": "electron/dock-icon.png",
        "to": "dock-icon.png"
      }
    ],
    "directories": {
      "output": "dist"
    }
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.97.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.34.2",
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "wait-on": "^9.0.4"
  }
}
